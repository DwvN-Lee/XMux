#compdef xmux

local state
typeset -A opt_args

local -a commands common_options
commands=(
  "start:start a Codex TUI XMux session"
  "attach:attach to an XMux tmux session"
  "stop:stop an XMux-owned tmux session"
  "sessions:list XMux tmux sessions"
  "setup-xmux:configure global Codex and Claude integration"
  "cleanup-legacy:remove legacy XMux 1.x state after review"
  "doctor-xmux:inspect XMux integration"
  "remove-xmux:remove XMux-managed global integration"
  "codex:operate the Codex pane harness"
  "claude:operate the Claude hook harness"
  "help:show help"
)
common_options=(
  "(-h --help)"{-h,--help}"[show help]"
  "(-V --version)"{-V,--version}"[show version]"
)

case "${words[2]:-}" in
  setup-xmux)
    _arguments -C \
      $common_options \
      "--with-skills[install XMux-managed skills]" \
      "--without-skills[skip XMux-managed skill install]" \
      "--refresh[refresh XMux-managed assets]" \
      "--dry-run[show planned changes]" \
      "--without-codex[skip Codex global integration]" \
      "--without-claude[skip Claude global integration]" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory]:directory:_directories" \
      "--ref[release tag recorded in installed metadata]:tag:"
    ;;
  doctor-xmux)
    _arguments -C \
      $common_options \
      "--quiet[exit with status only]" \
      "--json[write JSON output]" \
      "--without-codex[skip Codex global checks]" \
      "--without-claude[skip Claude global checks]" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory]:directory:_directories"
    ;;
  cleanup-legacy)
    _arguments -C \
      $common_options \
      "--dry-run[show planned removals]" \
      "--purge-archive[also remove legacy project archives]" \
      "--force[run even when legacy processes are detected]" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory]:directory:_directories"
    ;;
  remove-xmux)
    _arguments -C \
      $common_options \
      "--with-skills[also remove XMux-managed skills]" \
      "--without-skills[keep XMux-managed skills]" \
      "--dry-run[show planned removals]" \
      "--without-codex[skip Codex global removal]" \
      "--without-claude[skip Claude global removal]" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory]:directory:_directories"
    ;;
  attach)
    _arguments -C $common_options "1:session:"
    ;;
  stop)
    _arguments -C $common_options "1:session:"
    ;;
  claude)
    if (( CURRENT == 3 )); then
      _arguments -C \
        $common_options \
        "1:claude command:(sessions start ensure-hooks send send-codex trigger-codex read status stop pane-run hook)"
    else
      _arguments -C \
        $common_options \
        "--to[session name]:session:" \
        "--name[session name]:session:" \
        "--trigger[required explicit trigger]:trigger:(xmux-claude xmux-claude\\! xmux-codex)" \
        "--prompt[prompt text]:text:" \
        "--stdin[read prompt from stdin]" \
        "--wait[wait for response]" \
        "--quiet[skip command output]" \
        "--json[write JSON output]" \
        "--split[record split-view preference]" \
        "--socket-timeout[socket timeout milliseconds]:milliseconds:" \
        "--claude-cmd[Claude TUI command for pane-run]:command:"
    fi
    ;;
  codex|xmux-codex)
    if (( CURRENT == 3 )); then
      _arguments -C \
        $common_options \
        "1:codex command:(sessions ensure-hooks status send stop pane-run hook)"
    else
      _arguments -C \
        $common_options \
        "--to[session name]:session:" \
        "--name[session name]:session:" \
        "--prompt[prompt text]:text:" \
        "--stdin[read prompt from stdin]" \
        "--prompt-file[read prompt from file]:file:_files" \
        "--clear[clear the current prompt before injection]" \
        "--no-enter[stage prompt without pressing enter]" \
        "--json[write JSON output]" \
        "--socket-timeout[socket timeout milliseconds]:milliseconds:" \
        "--codex-cmd[Codex TUI command for pane-run]:command:"
    fi
    ;;
  *)
    if (( CURRENT == 2 )); then
      _describe -t commands "xmux command" commands
    else
      _arguments -C \
        $common_options \
        "-n[tmux session name]:session:" \
        "--codex-bin[Codex TUI command]:command:" \
        "*:Codex argument:_files"
    fi
    ;;
esac
