#compdef xmux

local state
typeset -A opt_args

local -a commands common_options
commands=(
  "start:start the Codex lead"
  "setup-xmux:configure XMux Codex and Claude integration"
  "doctor-xmux:inspect XMux integration"
  "remove-xmux:remove XMux-managed global integration"
  "codex:operate the Codex pane harness"
  "claude:operate the Claude hook harness"
  "theme-reset:reset temporary XMux terminal theme"
  "help:show user, agent, or debug help"
)
common_options=(
  "(-h --help)"{-h,--help}"[show help]"
  "(-V --version)"{-V,--version}"[show version]"
)

case "${words[2]:-}" in
  help)
    _arguments -C \
      $common_options \
      "1:help topic:(user debug all)"
    ;;
  teamCreate|teammateAdd|teammateStatus|teammateShutdown|teamShutdown|teamStatus|teammates|ensure|bridgeStatus|recover|shutdown|sendPane|gemini|copilot)
    _message "disabled in the Claude hook harness"
    ;;
  doctor)
    _arguments -C \
      $common_options \
      "-t[team name]:team:" \
      "-T[team name]:team:" \
      "--session[tmux session name]:session:" \
      "--json[write JSON output]" \
      "*:argument:_files"
    ;;
  setup-xmux)
    _arguments -C \
      $common_options \
      "--with-skills[install XMux-managed Codex skills]" \
      "--without-skills[skip XMux-managed Codex skill install]" \
      "--refresh[refresh XMux-managed assets]" \
      "--dry-run[show planned changes]" \
      "--without-codex[skip Codex global integration]" \
      "--without-claude[skip Claude global integration]" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory]:directory:_directories" \
      "--ref[release tag recorded in installed metadata]:tag:"
    ;;
  doctor-xmux)
    _arguments -C \
      $common_options \
      "--quiet[exit with status only]" \
      "--json[write JSON output]" \
      "--without-codex[skip Codex global checks]" \
      "--without-claude[skip Claude global checks]" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory]:directory:_directories"
    ;;
  remove-xmux)
    _arguments -C \
      $common_options \
      "--with-skills[also remove XMux-managed Codex skills]" \
      "--without-skills[keep XMux-managed Codex skills]" \
      "--dry-run[show planned removals]" \
      "--without-codex[skip Codex global removal]" \
      "--without-claude[skip Claude global removal]" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory]:directory:_directories"
    ;;
  sessions)
    _arguments -C \
      $common_options \
      "--filter[session filter]:pattern:" \
      "--all[include all sessions]"
    ;;
  paneInfo|attach)
    _arguments -C \
      $common_options \
      "-t[team name]:team:" \
      "-T[team name]:team:" \
      "*:target or argument:_files"
    ;;
  claude)
    if (( CURRENT == 3 )); then
      _arguments -C \
        $common_options \
        "1:claude command:(sessions start ensure-hooks send read status stop pane-run hook)"
    else
      _arguments -C \
        $common_options \
        "--to[Claude session name]:session:" \
        "--name[Claude session name]:session:" \
        "--trigger[required skill trigger]:trigger:(xmux-claude xmux-claude\\!)" \
        "--prompt[prompt text]:text:" \
        "--stdin[read prompt from stdin]" \
        "--wait[wait for response]" \
        "--json[write JSON output]" \
        "--split[record split-view preference]" \
        "--socket-timeout[socket timeout milliseconds]:milliseconds:" \
        "--startup-delay[delay before first prompt injection into a new pane]:milliseconds:" \
        "--claude-cmd[Claude TUI command for pane-run]:command:"
    fi
    ;;
  codex|xmux-codex)
    if (( CURRENT == 3 )); then
      _arguments -C \
        $common_options \
        "1:codex command:(sessions ensure-hooks status send stop pane-run hook)"
    else
      _arguments -C \
        $common_options \
        "--to[Codex session name]:session:" \
        "--name[Codex session name]:session:" \
        "--prompt[prompt text]:text:" \
        "--stdin[read prompt from stdin]" \
        "--prompt-file[read prompt from file]:file:_files" \
        "--clear[clear the current Codex prompt before injection]" \
        "--no-enter[stage prompt without pressing enter]" \
        "--json[write JSON output]" \
        "--socket-timeout[socket timeout milliseconds]:milliseconds:" \
        "--codex-cmd[Codex TUI command for pane-run]:command:"
    fi
    ;;
  *)
    if (( CURRENT == 2 )); then
      _describe -t commands "xmux command" commands
    else
      _arguments -C \
        $common_options \
        "-n[tmux session name]:session:" \
        "-T[team name]:team:" \
        "--shutdown-on-lead-exit[shutdown lead runtime when Codex exits]" \
        "--keep-team-on-lead-exit[leave the lead runtime available after Codex exits]" \
        "*:argument:_files"
    fi
    ;;
esac
