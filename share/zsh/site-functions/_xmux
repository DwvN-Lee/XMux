#compdef xmux

local state
typeset -A opt_args

local -a commands providers common_options
commands=(
  "start:start the Codex lead"
  "setup-codex:configure explicit Codex integration"
  "doctor-codex:inspect explicit Codex integration"
  "remove-codex:remove explicit Codex integration"
  "help:show user, agent, or debug help"
)
providers=(claude gemini copilot)
common_options=(
  "(-h --help)"{-h,--help}"[show help]"
  "(-V --version)"{-V,--version}"[show version]"
)

case "${words[2]:-}" in
  help)
    _arguments -C \
      $common_options \
      "1:help topic:(user agent debug all)"
    ;;
  teamCreate)
    _arguments -C \
      $common_options \
      "-t[team name]:team:" \
      "-T[team name]:team:" \
      "-n[tmux session name]:session:" \
      "--with[provider list]" \
      "--shutdown-on-lead-exit[shutdown teammates when lead exits]" \
      "--keep-team-on-lead-exit[leave teammates running when lead exits]" \
      "*:provider or Codex argument:->provider"
    ;;
  teammateAdd)
    _arguments -C \
      $common_options \
      "-t[team name]:team:" \
      "-T[team name]:team:" \
      "--session[tmux session name]:session:" \
      "*:provider:->provider"
    ;;
  teammateStatus|teammateShutdown|teamShutdown|teamStatus|teammates|ensure|doctor|bridgeStatus|recover|shutdown)
    _arguments -C \
      $common_options \
      "-t[team name]:team:" \
      "-T[team name]:team:" \
      "--session[tmux session name]:session:" \
      "--json[write JSON output]" \
      "*:argument:_files"
    ;;
  setup-codex)
    _arguments -C \
      $common_options \
      "--without-skills[skip XMux Codex skill refresh]" \
      "--skills-dir[XMux Codex skills source directory]:directory:_directories" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory with .codex config]:directory:_directories"
    ;;
  doctor-codex)
    _arguments -C \
      $common_options \
      "--quiet[exit with status only]" \
      "--skills-dir[XMux Codex skills source directory]:directory:_directories" \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory with .codex config]:directory:_directories"
    ;;
  remove-codex)
    _arguments -C \
      $common_options \
      "--home[Codex home directory]:directory:_directories" \
      "--project[project directory with .codex config]:directory:_directories"
    ;;
  sessions)
    _arguments -C \
      $common_options \
      "--filter[session filter]:pattern:" \
      "--all[include all sessions]"
    ;;
  paneInfo|sendPane|attach)
    _arguments -C \
      $common_options \
      "-t[team name]:team:" \
      "-T[team name]:team:" \
      "*:target or argument:_files"
    ;;
  claude|gemini|copilot)
    _arguments -C \
      $common_options \
      "-t[team name]:team:" \
      "-T[team name]:team:" \
      "-n[agent name]:agent:" \
      "-x[timeout seconds]:seconds:"
    ;;
  *)
    if (( CURRENT == 2 )); then
      _describe -t commands "xmux command" commands
    else
      _arguments -C \
        $common_options \
        "-n[tmux session name]:session:" \
        "-T[team name]:team:" \
        "--shutdown-on-lead-exit[shutdown teammates when lead exits]" \
        "--keep-team-on-lead-exit[leave teammates running when lead exits]" \
        "*:argument:_files"
    fi
    ;;
esac

case "$state" in
  provider)
    _describe -t providers "provider" providers
    ;;
esac
